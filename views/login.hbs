<div class="min-h-screen flex items-center justify-center p-4">
    <div class="glass p-8 rounded-3xl w-full max-w-md shadow-2xl animate-in fade-in slide-in-from-bottom-4 duration-700">
        <div class="text-center mb-8">
            <h1 id="formTitle" class="text-4xl font-bold bg-gradient-to-r from-indigo-400 to-indigo-600 bg-clip-text text-transparent mb-2">Welcome Back</h1>
            <p id="formSubtitle" class="text-slate-400">Enter your credentials to access the system.</p>
        </div>

        <div class="flex p-1 bg-slate-900/50 rounded-xl mb-8">
            <button id="loginTab" class="flex-1 py-2 text-sm font-semibold rounded-lg bg-indigo-600 text-white transition-all">Login</button>
            <button id="registerTab" class="flex-1 py-2 text-sm font-semibold text-slate-400 hover:text-slate-200 transition-all">Register</button>
        </div>

        <form id="authForm" class="space-y-5">
            <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2 px-1">Email Address</label>
                <input type="email" id="email" required placeholder="name@company.com" 
                    class="w-full bg-slate-900/50 border border-slate-700 rounded-xl px-4 py-3 text-slate-200 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition-all">
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2 px-1">Password</label>
                <input type="password" id="password" required placeholder="••••••••" 
                    class="w-full bg-slate-900/50 border border-slate-700 rounded-xl px-4 py-3 text-slate-200 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition-all">
            </div>
            
            <button type="submit" id="submitBtn" 
                class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3 rounded-xl shadow-lg shadow-indigo-600/20 transform active:scale-[0.98] transition-all">
                Sign In
            </button>
        </form>

        <div id="message" class="mt-6 p-4 rounded-xl text-sm border hidden text-center"></div>
    </div>
</div>

<script>
    const authForm = document.getElementById('authForm');
    const loginTab = document.getElementById('loginTab');
    const registerTab = document.getElementById('registerTab');
    const formTitle = document.getElementById('formTitle');
    const formSubtitle = document.getElementById('formSubtitle');
    const submitBtn = document.getElementById('submitBtn');
    const messageDiv = document.getElementById('message');

    let isLogin = true;

    function toggleTab(toLogin) {
        isLogin = toLogin;
        loginTab.className = isLogin ? 'flex-1 py-2 text-sm font-semibold rounded-lg bg-indigo-600 text-white transition-all' : 'flex-1 py-2 text-sm font-semibold text-slate-400 hover:text-slate-200 transition-all';
        registerTab.className = !isLogin ? 'flex-1 py-2 text-sm font-semibold rounded-lg bg-indigo-600 text-white transition-all' : 'flex-1 py-2 text-sm font-semibold text-slate-400 hover:text-slate-200 transition-all';
        
        formTitle.textContent = isLogin ? 'Welcome Back' : 'Create Account';
        formSubtitle.textContent = isLogin ? 'Enter your credentials to access the system.' : 'Join us to access all premium features.';
        submitBtn.textContent = isLogin ? 'Sign In' : 'Sign Up';
        messageDiv.classList.add('hidden');
    }

    loginTab.onclick = () => toggleTab(true);
    registerTab.onclick = () => toggleTab(false);

    authForm.onsubmit = async (e) => {
        e.preventDefault();
        const email = document.getElementById('email').value;
        const pass = document.getElementById('password').value;

        submitBtn.disabled = true;
        submitBtn.textContent = isLogin ? 'Authenticating...' : 'Registering...';
        messageDiv.className = 'mt-6 p-4 rounded-xl text-sm border hidden text-center';

        try {
            const endpoint = isLogin ? '/auth/login' : '/auth/register';
            const response = await fetch(endpoint, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, pass })
            });

            const data = await response.json();

            if (response.ok) {
                if (isLogin) {
                    messageDiv.textContent = 'Login Successful! Redirecting...';
                    messageDiv.classList.remove('hidden');
                    messageDiv.classList.add('bg-emerald-500/10', 'text-emerald-400', 'border-emerald-500/20');
                    
                    document.cookie = `access_token=${data.access_token}; path=/; max-age=3600; SameSite=Strict`;
                    
                    const token = data.access_token;
                    const payload = JSON.parse(atob(token.split('.')[1]));
                    
                    setTimeout(() => {
                        if (payload.permissions === '11111') {
                            window.location.href = '/admin';
                        } else {
                            window.location.href = '/';
                        }
                    }, 1000);
                } else {
                    messageDiv.textContent = 'Registration successful! You can now login.';
                    messageDiv.classList.remove('hidden');
                    messageDiv.classList.add('bg-emerald-500/10', 'text-emerald-400', 'border-emerald-500/20');
                    toggleTab(true);
                }
            } else {
                messageDiv.textContent = data.message || 'Authentication failed';
                messageDiv.classList.remove('hidden');
                messageDiv.classList.add('bg-rose-500/10', 'text-rose-400', 'border-rose-500/20');
            }
        } catch (err) {
            messageDiv.textContent = 'Connection error. Please try again.';
            messageDiv.classList.remove('hidden');
            messageDiv.classList.add('bg-rose-500/10', 'text-rose-400', 'border-rose-500/20');
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = isLogin ? 'Sign In' : 'Sign Up';
        }
    };
</script>
